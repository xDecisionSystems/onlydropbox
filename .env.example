# Linux user inside the container used to run Dropbox (non-root).
DROPBOX_USER=dropbox

# Base Dropbox path where selective sync rules are applied.
# Use "/" for Dropbox root.
PREFIX_PATH=/

# Comma-separated list of folder paths to sync within PREFIX_PATH.
# Spaces around commas are allowed.
# Example:
# SYNC_FOLDERS=Work, Photos, Apps/Overleaf
SYNC_FOLDERS=
