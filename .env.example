# Required LXC-style account path values for Docker mode.
# ACCOUNT_ROOT=UCF Dropbox
# ACCOUNT_NAME=John Doe
ACCOUNT_ROOT=
ACCOUNT_NAME=

# Comma-separated list of folder paths to sync within ACCOUNT_ROOT/ACCOUNT_NAME.
# Spaces around commas are allowed.
# Example:
# SYNC_FOLDERS=Work, Photos, Apps/Overleaf
SYNC_FOLDERS=
